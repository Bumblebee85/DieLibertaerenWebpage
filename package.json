{
  "name": "die-libertaeren-webpage",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "cross-env NODE_OPTIONS=--no-deprecation next dev --port 3010",
    "build": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap && cross-env NODE_OPTIONS=\"--no-deprecation --max-old-space-size=8000\" next build",
    "check:payload": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/check-payload-env.ts",
    "seed:admin": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-admin.ts",
    "start": "cross-env NODE_OPTIONS=--no-deprecation next start",
    "lint": "eslint",
    "payload": "cross-env NODE_OPTIONS=--no-deprecation payload",
    "generate:importmap": "cross-env NODE_OPTIONS=--no-deprecation payload generate:importmap",
    "generate:types": "cross-env NODE_OPTIONS=--no-deprecation payload generate:types",
    "seed:highlights": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-highlights.ts",
    "seed:quotes": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-quotes.ts",
    "seed:impulses": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-impulses.ts",
    "seed:content": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-content.ts",
    "seed:remote": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-remote.ts",
    "seed:cms": "cross-env NODE_OPTIONS=--no-deprecation tsx src/scripts/seed-cms.ts"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@payloadcms/db-mongodb": "^3.85.1",
    "@payloadcms/next": "^3.85.1",
    "@payloadcms/richtext-lexical": "^3.85.1",
    "@payloadcms/ui": "^3.85.1",
    "@radix-ui/react-accordion": "^1.2.14",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-navigation-menu": "^1.2.16",
    "@radix-ui/react-slot": "^1.3.0",
    "@radix-ui/react-tabs": "^1.1.15",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cross-env": "^10.1.0",
    "dotenv": "^17.4.2",
    "framer-motion": "^12.40.0",
    "graphql": "^16.14.2",
    "lucide-react": "^1.21.0",
    "next": "16.2.9",
    "payload": "^3.85.1",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "sharp": "^0.35.2",
    "tailwind-merge": "^3.6.0"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.9",
    "tailwindcss": "^4",
    "tsx": "^4.22.4",
    "typescript": "^5"
  }
}
